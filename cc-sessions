def cmd_hook():
    try:
        payload = json.load(sys.stdin)
    except Exception:
        sys.exit(0)

    event = payload.get('hook_event_name', '')
    sid = payload.get('session_id', '')
    cwd = payload.get('cwd', '')
    tp = payload.get('transcript_path', '')

    task = _resolve_task(cwd, tp)
    branch = shell_quiet(f"git -C {shlex.quote(cwd)} rev-parse --abbrev-ref HEAD") if cwd else ''

    INDEX_FILE.parent.mkdir(parents=True, exist_ok=True)
    with INDEX_FILE.open('a') as f:
        f.write(json.dumps({
            'ts': time.time(),
            'iso': datetime.now(timezone.utc).isoformat(),
            'event': event,
            'task': task,
            'session_id': sid,
            'cwd': cwd,
            'branch': branch,
            'transcript_path': tp,
            'reason': payload.get('reason'),
            'source': payload.get('source'),
        }) + '\n')

    if event == 'SessionStart':
        result = {}
        if branch:
            bm = re.match(r'^([A-Za-z]+-\d+)/(\d+)$', branch)
            if bm:
                result['ticket'] = bm.group(1)
                result['phase'] = int(bm.group(2))

        if task:
            NOTES_DIR.mkdir(parents=True, exist_ok=True)
            note = NOTES_DIR / f"{sanitize(task)}.md"
            if note.exists():
                content = note.read_text().strip()
                if content:
                    body = content
                    if body.startswith('---'):
                        end = body.find('---', 3)
                        if end > 0:
                            body = body[end + 3:].strip()
                    if body:
                        print(f"## Resuming task: {task}")
                        print(f"Prior session notes:\n\n{body[:4000]}")


def _resolve_task(cwd, tp):
    t = shell_quiet("tmux display-message -p '#W'")
    if t and t not in ('bash', 'zsh', 'fish', 'python', 'python3', 'node', 'claude'):
        return t
    t = os.environ.get('CC_TASK', '')
    if t:
        return t
    if tp and os.path.exists(tp):
        try:
            with open(tp) as f:
                for line in f:
                    d = json.loads(line)
                    if d.get('type') == 'custom-title' and d.get('customTitle'):
                        return extract_task_key(d['customTitle'])
        except Exception:
            pass
    if cwd:
        return pathlib.Path(cwd).name
    return 'untagged'


# ── Status ──────────────────────────────────────────────────────────

def cmd_status(task_query, new_status=None):
    sessions = scan_transcripts()
    q = task_query.lower()
    match_key = None
    for s in sessions:
        tk = s.get('task_key') or ''
        if q in tk.lower():
            match_key = tk
            break
    if not match_key:
        for s in sessions:
            t = (s.get('title') or '').lower()
            if q in t:
                match_key = s.get('task_key')
                break
    if not match_key:
        print(f"No task matching '{task_query}'", file=sys.stderr)
        sys.exit(1)
    if new_status:
        if new_status not in STATUSES:
            print(f"Invalid status '{new_status}'. Use: {', '.join(STATUSES)}", file=sys.stderr)
            sys.exit(1)
        _set_task_status(match_key, new_status)
        icon = STATUS_ICONS.get(new_status, '?')
        print(f"{icon} {match_key} → {new_status}")
    else:
        cur = _get_task_status(match_key)
        icon = STATUS_ICONS.get(cur, '?')
        print(f"{icon} {match_key}: {cur}")


# ── New session ─────────────────────────────────────────────────────

def _parse_new_input(text):
    text = text.strip()
    m = re.match(r'^([A-Za-z]+-\d+)/(\d+)\.(\d+):?\s+(.+)$', text)
    if m:
        return m.group(1), int(m.group(2)), int(m.group(3)), m.group(4)
    m = re.match(r'^([A-Za-z]+-\d+)/(\d+):?\s+(.+)$', text)
    if m:
        return m.group(1), int(m.group(2)), 1, m.group(3)
    m = re.match(r'^([A-Za-z]+-\d+):?\s+(.+)$', text)
    if m:
        return m.group(1), 1, 1, m.group(2)
    return None


def cmd_new(text):
    parsed = _parse_new_input(text)
    if not parsed:
        print("Usage: csm new 'TICKET Title' or 'TICKET/PHASE Title'", file=sys.stderr)
        print("  e.g. csm new 'SET-123 Implement settlements'", file=sys.stderr)
        print("       csm new 'SET-123/2 Implement settlements'", file=sys.stderr)
        print("       csm new 'SET-123/2.005: Implement settlements'", file=sys.stderr)
        sys.exit(1)
    ticket, phase, session, title = parsed
    full_title = f"{ticket}/{phase}.{session:03d}: {title}"
    os.execvp('claude', ['claude', '-n', full_title])


# ── Delete ──────────────────────────────────────────────────────────

def cmd_del(query):
    sessions = scan_transcripts()
    q = query.lower()
    matches = []
    for s in sessions:
        if s['session_id'].startswith(q):
            matches.append(s)
        elif q in (s.get('title') or '').lower():
            matches.append(s)
    if not matches:
        print(f"No session matching '{query}'", file=sys.stderr)
        sys.exit(1)
    if len(matches) > 1:
        print(f"Multiple matches ({len(matches)}):", file=sys.stderr)
        for s in matches[:10]:
            print(f"  {s['session_id'][:8]}  {s.get('title', '???')}", file=sys.stderr)
        print("Use a more specific query or session ID.", file=sys.stderr)
        sys.exit(1)
    s = matches[0]
    tp = s.get('transcript', '')
    sid = s['session_id'][:8]
    title = s.get('title') or '???'
    if tp and os.path.exists(tp):
        _trash_session(tp)
        print(f"Trashed: {sid}  {title}")
    else:
        print(f"Transcript not found: {tp}", file=sys.stderr)
        sys.exit(1)


def _trash_session(transcript_path):
    TRASH_DIR.mkdir(parents=True, exist_ok=True)
    src = pathlib.Path(transcript_path)
    dst = TRASH_DIR / src.name
    src.rename(dst)


# ── Clipboard ───────────────────────────────────────────────────────

def _autodetect_copy():
    if sys.platform == 'darwin' and shutil.which('pbcopy'):
        return 'pbcopy'
    if os.environ.get('WAYLAND_DISPLAY') and shutil.which('wl-copy'):
        return 'wl-copy'
    if shutil.which('xclip'):
        return 'xclip -selection clipboard'
    if shutil.which('xsel'):
        return 'xsel --clipboard --input'
    if shutil.which('clip.exe'):
        return 'clip.exe'
    if sys.platform.startswith('win') and shutil.which('clip'):
        return 'clip'
    return ''


def _copy_command():
    cmd = os.environ.get('CSM_COPY_CMD')
    if cmd is None:
        cmd = _load_config().get('copy', {}).get('command', '')
    cmd = (cmd or '').strip()
    if cmd == 'auto':
        return _autodetect_copy()
    return cmd


def _copy_to_clipboard(text):
    cmd = _copy_command()
    if not cmd:
        return False
    try:
        subprocess.run(cmd, shell=True, input=text.encode(),
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return True
    except Exception:
        return False


# ── Hop ─────────────────────────────────────────────────────────────

def _bump_version(title):
    nm = _naming()
    groups = _parse_title(title)
    bf = nm.get("bump_field")
    if groups and bf and bf in groups and groups[bf] is not None:
        try:
            groups = dict(groups)
            groups[bf] = str(int(groups[bf]) + 1)
            out = _render_title(nm.get("full_template", ""), groups, bf)
            if out:
                return out
        except (TypeError, ValueError):
            pass
    m = re.search(r'([-–—]\s*[vV])(\d+)\s*$', title)
    if m:
        num = int(m.group(2)) + 1
        width = len(m.group(2))
        return title[:m.start()] + m.group(1) + str(num).zfill(width)
    m = re.search(r'([-–—]\s*#)(\d+)\s*$', title)
    if m:
        return title[:m.start()] + m.group(1) + str(int(m.group(2)) + 1)
    m = re.search(r'\(([vV])(\d+)\)\s*$', title)
    if m:
        return title[:m.start()] + f'({m.group(1)}{int(m.group(2)) + 1})'
    key = extract_task_key(title)
    return f"{key} - v002"


def cmd_hop(query=None, dry_run=False):
    sessions = scan_transcripts()
    match = None
    if query:
        q = query.lower()
        for s in sessions:
            if s['session_id'].startswith(q):
                match = s
                break
        if not match:
            for s in sessions:
                t = (s.get('title') or '').lower()
                if q in t:
                    match = s
                    break
    else:
        cwd = os.getcwd()
        cwd_sessions = [s for s in sessions if s.get('cwd', '').startswith(cwd)]
        if cwd_sessions:
            cwd_sessions.sort(key=lambda s: s.get('last_ts') or '', reverse=True)
            match = cwd_sessions[0]
    if not match:
        print(f"No session found{' matching ' + repr(query) if query else ' for ' + os.getcwd()}", file=sys.stderr)
        sys.exit(1)

    title = match.get('title') or 'Untitled'
    new_title = _bump_version(title)
    transcript = match.get('transcript', '')

    prompt = (
        f'Read the previous session transcript at {transcript} '
        f'(JSONL format: user messages in type=user message.content, '
        f'assistant messages in type=assistant message.content[].text). '
        f'Continue where we left off.'
    )
    if dry_run:
        clean = _strip_wrapping_quotes(title)
        self_path = os.path.abspath(__file__)
        line = f'{sys.executable} {shlex.quote(self_path)} hop "{clean}"'
        copied = _copy_to_clipboard(line)
        print(line)
        if copied:
            print('# copied to clipboard', file=sys.stderr)
    else:
        os.execvp('claude', ['claude', '-n', new_title, prompt])


# ── Config command ──────────────────────────────────────────────────

def cmd_config(init=False):
    path = _config_path()
    if init:
        if path.exists():
            print(f"Config already exists at {path}", file=sys.stderr)
            sys.exit(1)
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(json.dumps(DEFAULT_CONFIG, indent=2) + "\n")
        print(f"Wrote default config to {path}")
        print("Edit it to customize naming convention and clipboard copy.")
        return
    cfg = _load_config()
    copy_cmd = _copy_command()
    print(f"Config file: {path}{'' if path.exists() else '  (not present — using defaults)'}")
    print(f"Copy command: {copy_cmd or '(disabled)'}")
    print()
    print(json.dumps(cfg, indent=2))


# ── Main ─────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    if not args:
        cmd_pick()
        return

    cmd = args[0]
    if cmd in ('-h', '--help', 'help'):
        print(__doc__.strip())
    elif cmd == 'note':
        task = args[1] if len(args) > 1 else None
        text = args[2] if len(args) > 2 else None
        cmd_note(task, text)
    elif cmd == 'hook':
        cmd_hook()
    elif cmd == 'new':
        if len(args) < 2:
            print("Usage: csm new 'TICKET Title'", file=sys.stderr)
            sys.exit(1)
        cmd_new(' '.join(args[1:]))
    elif cmd in ('del', 'delete', 'rm'):
        if len(args) < 2:
            print("Usage: csm del <title-or-session-id>", file=sys.stderr)
            sys.exit(1)
        cmd_del(' '.join(args[1:]))
    elif cmd == 'hop':
        dry = '--dry-run' in args
        rest = [a for a in args[1:] if a != '--dry-run']
        cmd_hop(' '.join(rest) if rest else None, dry_run=dry)
    elif cmd == 'status':
        if len(args) < 2:
            print("Usage: cc-sessions status <task> [open|wip|done|blocked]", file=sys.stderr)
            sys.exit(1)
        new_st = args[-1] if len(args) > 2 and args[-1] in STATUSES else None
        task_q = ' '.join(args[1:] if not new_st else args[1:-1])
        cmd_status(task_q, new_st)
    elif cmd == 'config':
        cmd_config('--init' in args)
    elif cmd == 'index':
        if INDEX_FILE.exists():
            print(INDEX_FILE.read_text())
        else:
            print("No index yet. Populated by SessionStart/End hooks.")
    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        print(__doc__.strip(), file=sys.stderr)
        sys.exit(1)


if __name__ == '__main__':
    main()
