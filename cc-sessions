def _get_last_user_msg(transcript_path, max_chars=200):
    if not transcript_path or not os.path.exists(transcript_path):
        return None
    last_msg = None
    try:
        with open(transcript_path) as f:
            for line in f:
                try:
                    d = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if d.get('type') == 'user':
                    msg = d.get('message', {})
                    content = msg.get('content', '') if isinstance(msg, dict) else str(msg)
                    if isinstance(content, str):
                        clean = re.sub(r'<[^>]+>[^<]*', '', content).strip()
                        if len(clean) > 3:
                            last_msg = clean.replace('\n', ' ')[:max_chars]
    except Exception:
        pass
    return last_msg


def _get_task_note(task_key):
    if not task_key:
        return None
    note_file = NOTES_DIR / f"{sanitize(task_key)}.md"
    if note_file.exists():
        content = note_file.read_text().strip()
        if content:
            return content
    return None


STATUSES = ['open', 'wip', 'done', 'blocked']
STATUS_ICONS = {'open': '○', 'wip': '◐', 'done': '●', 'blocked': '◌'}
STATUS_COLORS = {'open': None, 'wip': _CP_YELLOW, 'done': _CP_GREEN, 'blocked': _CP_RED}


def _get_task_status(task_key):
    note = _get_task_note(task_key)
    if not note:
        return 'open'
    if note.startswith('---'):
        end = note.find('---', 3)
        if end > 0:
            front = note[3:end]
            m = re.search(r'^status:\s*(\w+)', front, re.MULTILINE)
            if m and m.group(1) in STATUSES:
                return m.group(1)
    return 'open'


def _set_task_status(task_key, status):
    if not task_key or status not in STATUSES:
        return
    NOTES_DIR.mkdir(parents=True, exist_ok=True)
    note_file = NOTES_DIR / f"{sanitize(task_key)}.md"
    if note_file.exists():
        content = note_file.read_text()
        if content.strip().startswith('---'):
            end = content.find('---', 3)
            if end > 0:
                front = content[3:end]
                body = content[end + 3:]
                if re.search(r'^status:', front, re.MULTILINE):
                    front = re.sub(r'^status:\s*\w+', f'status: {status}', front, flags=re.MULTILINE)
                else:
                    front = f'status: {status}\n' + front
                note_file.write_text(f'---{front}---{body}')
                return
        note_file.write_text(f'---\nstatus: {status}\n---\n{content}')
    else:
        note_file.write_text(f'---\nstatus: {status}\n---\n')


_CP_PANEL = 7
_CP_PBORDER = 8

def _draw_detail_panel(win, top_y, max_x, panel_h, session, sessions):
    if not session or panel_h < 3:
        return

    bg = curses.color_pair(_CP_PANEL)
    border_attr = curses.color_pair(_CP_PBORDER)
    inner_w = max_x - 4
    end_y = top_y + panel_h

    box_top = top_y + 1
    box_bot = end_y - 2
    try:
        win.addstr(box_top, 0, '╔' + '═' * (max_x - 2) + '╗', border_attr)
        for row in range(box_top + 1, box_bot):
            win.addstr(row, 0, '║', border_attr)
            win.addstr(row, 1, ' ' * (max_x - 2), bg)
            win.addstr(row, max_x - 1, '║', border_attr)
        win.addstr(box_bot, 0, '╚' + '═' * (max_x - 2) + '╝', border_attr)
    except curses.error:
        pass

    y = box_top + 1
    end_y = box_bot
    pad = 2

    title = session.get('title') or '???'
    task_key = session.get('task_key')
    status = _get_task_status(task_key) if task_key else 'open'
    si = STATUS_ICONS.get(status, '○')
    if session.get('renamed'):
        icon = '★ '
    elif session.get('title'):
        icon = '○ '
    else:
        icon = '· '
    status_label = f' [{status}]' if status != 'open' else ''
    try:
        win.addstr(y, pad, icon + title[:inner_w - len(icon) - len(status_label)],
                   curses.color_pair(_CP_PANEL_CYAN) | curses.A_BOLD)
        if status_label:
            sc = STATUS_COLORS.get(status)
            sattr = curses.color_pair(sc) if sc else curses.A_DIM
            win.addstr(status_label, sattr | curses.A_BOLD)
    except curses.error:
        pass
    y += 1

    if y < end_y - 1:
        cwd = session.get('cwd') or ''
        branch = session.get('branch') or ''
        parts = []
        if cwd:
            parts.append(cwd)
        if branch:
            parts.append(f'⎇ {branch}')
        meta = '  '.join(parts)
        try:
            win.addstr(y, pad, meta[:inner_w], bg | curses.A_DIM)
        except curses.error:
            pass
        y += 1

    if y < end_y - 1:
        ctx = session.get('ctx_tokens', 0)
        msgs = session.get('msg_count', 0)
        info = []
        if msgs:
            info.append(f"{msgs} msgs")
        if ctx:
            pct = min(ctx / 1_000_000 * 100, 100)
            info.append(f"ctx {pct:.0f}%")
        info.append(f"started {fmt_ts(session.get('first_ts', ''))}")
        info.append(f"last {fmt_ts(session.get('last_ts', ''))}")
        try:
            win.addstr(y, pad, ' · '.join(info)[:inner_w], bg | curses.A_DIM)
        except curses.error:
            pass
        y += 1

    task_key = session.get('task_key')
    note = _get_task_note(task_key)
    if note and y < end_y - 1:
        y += 1
        if y < end_y - 1:
            try:
                win.addstr(y, pad, 'Note:', bg | curses.color_pair(_CP_YELLOW) | curses.A_BOLD)
                win.addstr(y, pad + 6, note.split('\n')[0][:inner_w - 6], bg)
            except curses.error:
                pass
            y += 1
            for note_line in note.split('\n')[1:]:
                if y >= end_y - 1:
                    break
                try:
                    win.addstr(y, pad + 6, note_line[:inner_w - 6], bg)
                except curses.error:
                    pass
                y += 1

    last_msg = _get_last_user_msg(session.get('transcript'))
    if last_msg and y < end_y - 1:
        if not note:
            y += 1
        if y < end_y - 1:
            try:
                win.addstr(y, pad, 'Last:', bg | curses.A_DIM)
                win.addstr(y, pad + 6, last_msg[:inner_w - 6], bg | curses.A_DIM)
            except curses.error:
                pass


def _note_input(stdscr, max_y, max_x, task_key):
    if not task_key:
        return
    prompt = f' Note for "{task_key}": '
    try:
        stdscr.addstr(max_y - 1, 0, ' ' * (max_x - 1), curses.color_pair(_CP_YELLOW) | curses.A_BOLD)
        stdscr.addstr(max_y - 1, 0, prompt[:max_x - 1], curses.color_pair(_CP_YELLOW) | curses.A_BOLD)
    except curses.error:
        pass
    stdscr.refresh()
    curses.curs_set(1)

    note_text = ''
    input_start = len(prompt)
    while True:
        try:
            stdscr.move(max_y - 1, min(input_start + len(note_text), max_x - 1))
        except curses.error:
            pass
        stdscr.refresh()
        ch = stdscr.getch()
        if ch in (curses.KEY_ENTER, 10, 13):
            if note_text.strip():
                NOTES_DIR.mkdir(parents=True, exist_ok=True)
                note_file = NOTES_DIR / f"{sanitize(task_key)}.md"
                with note_file.open('a') as f:
                    f.write(f"\n{note_text.strip()}\n")
            curses.curs_set(0)
            return
        elif ch == 27 or ch == 3:
            curses.curs_set(0)
            return
        elif ch in (curses.KEY_BACKSPACE, 127, 8):
            if note_text:
                note_text = note_text[:-1]
                try:
                    stdscr.addstr(max_y - 1, input_start, note_text + ' ', curses.color_pair(_CP_YELLOW))
                except curses.error:
                    pass
        elif 32 <= ch <= 126:
            note_text += chr(ch)
            try:
                stdscr.addstr(max_y - 1, input_start, note_text[:max_x - input_start - 1], curses.color_pair(_CP_YELLOW))
            except curses.error:
                pass


def _text_input(stdscr, max_y, max_x, prompt, initial=''):
    """Inline editable text field on the bottom row. Returns text, or None on Esc."""
    text = initial
    label = curses.color_pair(_CP_YELLOW) | curses.A_BOLD
    input_start = len(prompt)
    curses.curs_set(1)
    while True:
        try:
            stdscr.addstr(max_y - 1, 0, ' ' * (max_x - 1), label)
            stdscr.addstr(max_y - 1, 0, prompt[:max_x - 1], label)
            stdscr.addstr(max_y - 1, input_start, text[:max_x - input_start - 1],
                          curses.color_pair(_CP_YELLOW))
            stdscr.move(max_y - 1, min(input_start + len(text), max_x - 1))
        except curses.error:
            pass
        stdscr.refresh()
        ch = stdscr.getch()
        if ch in (curses.KEY_ENTER, 10, 13):
            curses.curs_set(0)
            return text.strip()
        elif ch == 27 or ch == 3:
            curses.curs_set(0)
            return None
        elif ch in (curses.KEY_BACKSPACE, 127, 8):
            text = text[:-1]
        elif 32 <= ch <= 126:
            text += chr(ch)


def _confirm(stdscr, max_y, max_x, message):
    """Bottom-row y/N prompt. Returns True only on 'y'/'Y'."""
    attr = curses.color_pair(_CP_RED) | curses.A_BOLD
    try:
        stdscr.addstr(max_y - 1, 0, ' ' * (max_x - 1), attr)
        stdscr.addstr(max_y - 1, 0, message[:max_x - 1], attr)
    except curses.error:
        pass
    stdscr.refresh()
    while True:
        ch = stdscr.getch()
        if ch in (ord('y'), ord('Y')):
            return True
        if ch in (ord('n'), ord('N'), 27, 3, 10, 13):
            return False


def _rename_session(transcript_path, session_id, new_title):
    """Append a custom-title record — the same shape Claude Code's /rename writes."""
    if not transcript_path or not os.path.exists(transcript_path) or not new_title:
        return False
    rec = {"type": "custom-title", "customTitle": new_title, "sessionId": session_id}
    try:
        with open(transcript_path, 'a') as f:
            f.write(json.dumps(rec) + "\n")
        return True
    except OSError:
        return False


def _fuzzy_match(query, text):
    q = query.lower()
    t = text.lower()
    qi = 0
    for c in t:
        if qi < len(q) and c == q[qi]:
            qi += 1
    return qi == len(q)


def _tty_size():
    try:
        fd = os.open('/dev/tty', os.O_RDONLY)
        try:
            buf = fcntl.ioctl(fd, termios.TIOCGWINSZ, b'\x00' * 8)
            rows, cols = struct.unpack('HHHH', buf)[:2]
            if rows > 0 and cols > 0:
                return rows, cols
        finally:
            os.close(fd)
    except OSError:
        pass
    try:
        sz = os.get_terminal_size()
        return sz.lines, sz.columns
    except OSError:
        return 24, 80


def _pick_loop(stdscr, state):
    curses.start_color()
    curses.use_default_colors()
    curses.curs_set(0)
    stdscr.keypad(True)
    stdscr.timeout(250)
    curses.init_pair(_CP_CYAN, curses.COLOR_CYAN, -1)
    curses.init_pair(_CP_GREEN, curses.COLOR_GREEN, -1)
    curses.init_pair(_CP_YELLOW, curses.COLOR_YELLOW, -1)
    curses.init_pair(_CP_WHITE, curses.COLOR_WHITE, -1)
    curses.init_pair(_CP_RED, curses.COLOR_RED, -1)
    curses.init_pair(_CP_SEL, curses.COLOR_WHITE, 236)
    curses.init_pair(_CP_PANEL, 252, 235)
    curses.init_pair(_CP_PANEL + 1, curses.COLOR_GREEN, -1)  # border on default bg
    curses.init_pair(_CP_BAR, 252, 236)
    curses.init_pair(_CP_BAR_ACC, curses.COLOR_CYAN, -1)  # used with A_REVERSE
    curses.init_pair(_CP_PANEL_CYAN, curses.COLOR_CYAN, 235)

    scope = 'cwd'
    view_idx = 0
    query = ''
    cursor = 0
    scroll = 0
    prev_w = prev_h = -1
    show_panel = True
    PANEL_H = 10

    while True:
        sessions = state['sessions']

        real_h, real_w = _tty_size()
        cur_h, cur_w = stdscr.getmaxyx()
        if real_w != cur_w or real_h != cur_h:
            try:
                curses.resizeterm(real_h, real_w)
            except curses.error:
                pass
            stdscr.clear()

        max_y, max_x = stdscr.getmaxyx()

        if max_y < 3 or max_x < 40:
            stdscr.erase()
            try:
                stdscr.addstr(0, 0, 'Terminal too small', curses.A_BOLD)
            except curses.error:
                pass
            stdscr.refresh()
            ch = stdscr.getch()
            if ch == 27 or ch == 3:
                return None
            continue

        all_rows = _build_rows(sessions, scope, view_idx)
        total = sum(1 for r in all_rows if not r['is_header'])

        if query:
            rows = [r for r in all_rows if not r['is_header']
                    and _fuzzy_match(query, ANSI_RE.sub('', r['name_str']))]
        else:
            rows = all_rows

        sel_indices = [i for i, r in enumerate(rows) if not r['is_header']]
        n_sel = len(sel_indices)
        if n_sel > 0:
            cursor = max(0, min(cursor, n_sel - 1))
        else:
            cursor = 0
        cursor_row = sel_indices[cursor] if n_sel > 0 else -1

        cur_session = None
        if cursor_row >= 0:
            sid = rows[cursor_row]['sid']
            if sid and sid != '__header__':
                for s in sessions:
                    if s['session_id'] == sid:
                        cur_session = s
                        break

        panel_h = PANEL_H if (show_panel and cur_session and max_y > 20) else 0
        list_start = 1
        list_h = max_y - 4 - panel_h
        if cursor_row >= 0:
            if cursor_row < scroll:
                scroll = cursor_row
            elif cursor_row >= scroll + list_h:
                scroll = cursor_row - list_h + 1
        scroll = max(0, min(scroll, max(0, len(rows) - list_h)))

        if max_x != prev_w or max_y != prev_h:
            stdscr.clear()
            prev_w, prev_h = max_x, max_y
        else:
            stdscr.erase()

        _draw_tab_bar(stdscr, 0, max_x, scope, view_idx)

        for i in range(list_h):
            ri = scroll + i
            if ri >= len(rows):
                break
            _draw_row(stdscr, list_start + i, max_x, rows[ri],
                      selected=(ri == cursor_row))

        if panel_h > 0 and cur_session:
            panel_top = list_start + list_h
            _draw_detail_panel(stdscr, panel_top, max_x, panel_h, cur_session, sessions)

        hints = '  Tab: scope  ⇧Tab: view  ^E: rename  ^O: note  ^S: status  ^X: del  ^R: refresh  ^D: panel' if not query else ''
        right_info = f' {n_sel}/{total}{hints} '
        rule_attr = curses.color_pair(_CP_CYAN)
        label_attr = curses.color_pair(_CP_BAR_ACC) | curses.A_REVERSE
        try:
            stdscr.addstr(max_y - 3, 0, '─' * (max_x - 1), rule_attr)
            stdscr.addstr(max_y - 3, max_x - len(right_info) - 1, right_info, label_attr)
        except curses.error:
            pass
        try:
            stdscr.addstr(max_y - 1, 0, '─' * (max_x - 1), rule_attr)
        except curses.error:
            pass
        try:
            stdscr.addstr(max_y - 2, 0, '❯ ', curses.color_pair(_CP_CYAN) | curses.A_BOLD)
            q_max = max_x - 3
            stdscr.addstr(max_y - 2, 2, query[:q_max])
        except curses.error:
            pass

        stdscr.refresh()

        ch = stdscr.getch()
        if ch == -1 or ch == curses.KEY_RESIZE:
            continue
        elif ch == curses.KEY_UP or ch == 16:
            if cursor > 0:
                cursor -= 1
        elif ch == curses.KEY_DOWN or ch == 14:
            if cursor < n_sel - 1:
                cursor += 1
        elif ch in (curses.KEY_ENTER, 10, 13):
            if n_sel > 0 and cursor_row >= 0:
                sid = rows[cursor_row]['sid']
                if sid and sid != '__header__':
                    for s in sessions:
                        if s['session_id'] == sid:
                            return s
            return None
        elif ch == 27 or ch == 3:
            return None
        elif ch == 9:  # Tab = toggle scope
            scope = 'all' if scope == 'cwd' else 'cwd'
            cursor = 0
            scroll = 0
        elif ch == curses.KEY_BTAB:  # Shift+Tab = cycle view
            view_idx = (view_idx + 1) % len(VIEWS)
            cursor = 0
            scroll = 0
        elif ch in (curses.KEY_BACKSPACE, 127, 8):
            if query:
                query = query[:-1]
                cursor = 0
                scroll = 0
        elif ch == 15 and cur_session:  # Ctrl+O = note
            task_key = cur_session.get('task_key')
            if task_key:
                _note_input(stdscr, max_y, max_x, task_key)
                stdscr.clear()
        elif ch == 19 and cur_session:  # Ctrl+S = cycle status
            task_key = cur_session.get('task_key')
            if task_key:
                cur_status = _get_task_status(task_key)
                idx = STATUSES.index(cur_status) if cur_status in STATUSES else 0
                new_status = STATUSES[(idx + 1) % len(STATUSES)]
                _set_task_status(task_key, new_status)
                stdscr.clear()
        elif ch == 5 and cur_session:  # Ctrl+E = rename session
            tp = cur_session.get('transcript', '')
            sid = cur_session.get('session_id', '')
            cur_title = cur_session.get('title') or ''
            new = _text_input(stdscr, max_y, max_x, ' Rename: ', cur_title)
            if new and new != cur_title and _rename_session(tp, sid, new):
                cur_session['title'] = new
                cur_session['renamed'] = True
                cur_session['task_key'] = extract_task_key(new)
                state['sig'] = _transcript_signature()
            stdscr.clear()
        elif ch == 24 and cur_session:  # Ctrl+X = trash session (with confirm)
            tp = cur_session.get('transcript', '')
            title = cur_session.get('title') or cur_session.get('session_id', '')[:8]
            if tp and os.path.exists(tp):
                if _confirm(stdscr, max_y, max_x, f' Delete "{title[:max_x - 24]}"?  (y/N) '):
                    _trash_session(tp)
                    state['sessions'] = [s for s in sessions if s.get('transcript') != tp]
                    state['sig'] = _transcript_signature()
                    cursor = 0
                    scroll = 0
                stdscr.clear()
        elif ch == 18:  # Ctrl+R = force refresh
            state['sessions'] = scan_transcripts()
            state['sig'] = _transcript_signature()
            stdscr.clear()
        elif ch == 4:  # Ctrl+D = toggle detail panel
            show_panel = not show_panel
            stdscr.clear()
        elif 32 <= ch <= 126:
            query += chr(ch)
            cursor = 0
            scroll = 0


