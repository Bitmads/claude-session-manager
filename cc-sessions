#!/usr/bin/env python3
"""
cc-sessions — Claude Code session manager.
Interactive curses picker to browse, search, and resume sessions.

Usage:
    cc-sessions                              Interactive picker
    cc-sessions new TICKET [/PHASE] Title    Start new session (normalized)
    cc-sessions hop [TITLE|ID] [--dry-run]   Hop to next session version
    cc-sessions del TITLE|ID                 Delete a session transcript
    cc-sessions status TASK [STATUS]          Get/set task status
    cc-sessions note [TASK] [TXT]            View/edit task scratchpad
    cc-sessions config [--init]              Show/create config file
    cc-sessions hook                         Hook entry point (stdin JSON)

Config: ~/.claude/csm.json (or $CSM_CONFIG). See `cc-sessions config`.
"""

import json, sys, os, re, time, subprocess, pathlib, shlex, shutil, curses
import fcntl, struct, termios, threading
from collections import defaultdict
from datetime import datetime, timezone

CLAUDE_DIR = pathlib.Path.home() / ".claude"
PROJECTS_DIR = CLAUDE_DIR / "projects"
INDEX_FILE = CLAUDE_DIR / "task-index.jsonl"
NOTES_DIR = CLAUDE_DIR / "task-notes"
TRASH_DIR = CLAUDE_DIR / "trash"


# ── Configuration ────────────────────────────────────────────────────
#
# Overridable via a JSON config file at ~/.claude/csm.json (or $CSM_CONFIG).
# Zero config = these defaults, which match the SET-123/1.001: Title scheme.

DEFAULT_CONFIG = {
    "copy": {
        # Shell command the hop line is piped into. Empty = disabled.
        # "auto" = detect pbcopy / wl-copy / xclip / xsel / clip.exe.
        # Overridable per-invocation with the $CSM_COPY_CMD env var.
        "command": "",
    },
    "naming": {
        # Named-group regex that parses a session title.
        "pattern": r"^(?P<ticket>[A-Za-z]+-\d+)/(?P<phase>\d+)\.(?P<session>\d{3}):\s*(?P<title>.+)$",
        # Template to rebuild the full title (str.format with the groups).
        "full_template": "{ticket}/{phase}.{session:03d}: {title}",
        # Template to rebuild the grouping key (usually omits bump_field).
        "group_template": "{ticket}/{phase}: {title}",
        # Which named group `hop` increments (must be numeric).
        "bump_field": "session",
    },
}

_CONFIG = None


def _config_path():
    p = os.environ.get("CSM_CONFIG")
    return pathlib.Path(p) if p else CLAUDE_DIR / "csm.json"


def _load_config():
    global _CONFIG
    if _CONFIG is not None:
        return _CONFIG
    cfg = {k: dict(v) for k, v in DEFAULT_CONFIG.items()}
    path = _config_path()
    try:
        if path.exists():
            user = json.loads(path.read_text())
            for section, vals in user.items():
                if isinstance(vals, dict) and isinstance(cfg.get(section), dict):
                    cfg[section].update(vals)
                else:
                    cfg[section] = vals
    except Exception as e:
        print(f"csm: ignoring bad config at {path}: {e}", file=sys.stderr)
    _CONFIG = cfg
    return cfg


def _naming():
    return _load_config().get("naming", DEFAULT_CONFIG["naming"])

# ── Colors (ANSI for hooks/notes, curses pairs for picker) ──────────

C_RESET   = '\033[0m'
C_BOLD    = '\033[1m'
C_DIM     = '\033[2m'
C_CYAN    = '\033[36m'
C_BCYAN   = '\033[1;36m'
C_YELLOW  = '\033[33m'
C_BYELLOW = '\033[1;33m'
C_GREEN   = '\033[32m'
C_MAGENTA = '\033[35m'
C_WHITE   = '\033[37m'
C_BWHITE  = '\033[1;37m'

T_BRANCH  = '├──'
T_LAST    = '└──'

ANSI_RE = re.compile(r'\033\[[0-9;]*[a-zA-Z]')


def _vis_len(s):
    return len(ANSI_RE.sub('', s))


def _ansi_truncate(s, max_visible):
    result, visible, i = [], 0, 0
    while i < len(s):
        if s[i] == '\033' and i + 1 < len(s) and s[i + 1] == '[':
            j = i + 2
            while j < len(s) and not s[j].isalpha():
                j += 1
            if j < len(s):
                j += 1
            result.append(s[i:j])
            i = j
        else:
            if visible >= max_visible:
                break
            result.append(s[i])
            visible += 1
            i += 1
    result.append('\033[0m')
    return ''.join(result)


# ── Task key extraction (config-driven) ──────────────────────────────

def _strip_wrapping_quotes(s):
    s = s.strip()
    while len(s) >= 2 and s[0] == s[-1] and s[0] in '"\'':
        s = s[1:-1].strip()
    return s


def _parse_title(title):
    """Parse a title with the configured pattern → dict of named groups (strings), or None."""
    if not title:
        return None
    pattern = _naming().get("pattern")
    if not pattern:
        return None
    try:
        m = re.match(pattern, _strip_wrapping_quotes(title))
    except re.error:
        return None
    return m.groupdict() if m else None


def _render_title(template, groups, bump_field=None):
    """Rebuild a title from a template + groups. bump_field is coerced to int so {x:03d} works."""
    fmt = dict(groups)
    if bump_field and fmt.get(bump_field) is not None:
        try:
            fmt[bump_field] = int(fmt[bump_field])
        except (TypeError, ValueError):
            pass
    try:
        return template.format(**fmt)
    except Exception:
        return None


# Back-compat alias used elsewhere; returns parsed groups or None.
def _parse_ticket_title(title):
    return _parse_title(title)


def extract_task_key(title):
    if not title:
        return None
    nm = _naming()
    groups = _parse_title(title)
    if groups:
        key = _render_title(nm.get("group_template", ""), groups, nm.get("bump_field"))
        if key:
            return key
    s = _strip_wrapping_quotes(title)
    s = re.sub(r'^\[[\w\s/]+\]\s*[-–—]?\s*', '', s)
    s = re.sub(r'^(DONE|WIP|TODO|INIT)\s*[-–—]\s*', '', s, flags=re.IGNORECASE)
    s = re.sub(r'\s*[-–—]\s*[vV]?\d+\s*$', '', s)
    s = re.sub(r'\s*[-–—]\s*#\d+\s*$', '', s)
    s = re.sub(r'\s*\([vV]?\d+\)\s*$', '', s)
    return s.strip() or title.strip()


# ── Transcript scanning ──────────────────────────────────────────────

def scan_transcripts():
    sessions = []
    if not PROJECTS_DIR.exists():
        return sessions
    for proj_dir in PROJECTS_DIR.iterdir():
        if not proj_dir.is_dir():
            continue
        for jsonl_file in proj_dir.glob("*.jsonl"):
            s = _parse_transcript(jsonl_file, proj_dir.name)
            if s:
                sessions.append(s)
    return sessions


def _transcript_signature():
    """Cheap stat-only fingerprint of all transcripts. Changes on any
    create/delete (count) or append/rename (mtime). No file parsing."""
    count = 0
    newest = 0
    if PROJECTS_DIR.exists():
        for proj_dir in PROJECTS_DIR.iterdir():
            if not proj_dir.is_dir():
                continue
            for f in proj_dir.glob("*.jsonl"):
                try:
                    count += 1
                    m = f.stat().st_mtime_ns
                    if m > newest:
                        newest = m
                except OSError:
                    pass
    return (count, newest)


def _parse_transcript(path, proj_name):
    custom_title = ai_title = first_user_msg = None
    session_id = None
    first_ts = last_ts = None
    branch = cwd = None
    msg_count = 0
    last_ctx_tokens = 0

    try:
        with open(path) as f:
            for line in f:
                try:
                    d = json.loads(line)
                except json.JSONDecodeError:
                    continue
                t = d.get('type')
                if t == 'custom-title' and d.get('customTitle'):
                    custom_title = d['customTitle']
                    session_id = d.get('sessionId')
                elif t == 'ai-title' and d.get('aiTitle'):
                    ai_title = d['aiTitle']
                    if not session_id:
                        session_id = d.get('sessionId')
                ts = d.get('timestamp')
                if ts:
                    if first_ts is None:
                        first_ts = ts
                    last_ts = ts
                if not branch and d.get('gitBranch'):
                    branch = d['gitBranch']
                if not cwd and d.get('cwd'):
                    cwd = d['cwd']
                if t == 'user':
                    msg_count += 1
                    if not first_user_msg:
                        msg = d.get('message', {})
                        content = msg.get('content', '') if isinstance(msg, dict) else str(msg)
                        if isinstance(content, str):
                            clean = re.sub(r'<[^>]+>[^<]*', '', content).strip()
                            if len(clean) > 3:
                                first_user_msg = clean[:300].replace('\n', ' ')
                elif t == 'assistant':
                    msg_count += 1
                    usage = d.get('message', {}).get('usage', {})
                    if usage:
                        ctx = (usage.get('input_tokens', 0)
                               + usage.get('cache_creation_input_tokens', 0)
                               + usage.get('cache_read_input_tokens', 0))
                        if ctx > last_ctx_tokens:
                            last_ctx_tokens = ctx
    except Exception:
        return None

    if not session_id:
        session_id = path.stem

    title = custom_title or ai_title or first_user_msg
    renamed = custom_title is not None
    auto_named = ai_title is not None

    return {
        'session_id': session_id,
        'title': title,
        'renamed': renamed,
        'auto_named': auto_named,
        'task_key': extract_task_key(title),
        'project': proj_name,
        'cwd': cwd,
        'branch': branch,
        'first_ts': first_ts,
        'last_ts': last_ts,
        'msg_count': msg_count,
        'ctx_tokens': last_ctx_tokens,
        'transcript': str(path),
    }


# ── Grouping ─────────────────────────────────────────────────────────

def group_sessions(sessions):
    groups = defaultdict(list)
    for s in sessions:
        key = s['task_key'] or f"(misc · {proj_label(s.get('project', ''))})"
        groups[key].append(s)
    for key in groups:
        groups[key].sort(key=lambda s: s.get('last_ts') or '', reverse=True)
    return sorted(
        groups.items(),
        key=lambda kv: max((s.get('last_ts') or '' for s in kv[1]), default=''),
        reverse=True,
    )


# ── Formatting helpers ───────────────────────────────────────────────

def fmt_ts(ts_str):
    if not ts_str:
        return '?'
    try:
        dt = datetime.fromisoformat(ts_str.replace('Z', '+00:00'))
        now = datetime.now(timezone.utc) if dt.tzinfo else datetime.now()
        if dt.tzinfo and not now.tzinfo:
            now = datetime.now(timezone.utc)
        delta = now - dt
        if delta.days > 30:
            return dt.strftime('%b %d')
        if delta.days > 0:
            return f"{delta.days}d ago"
        hrs = delta.seconds // 3600
        if hrs > 0:
            return f"{hrs}h ago"
        mins = delta.seconds // 60
        if mins > 0:
            return f"{mins}m ago"
        return "now"
    except Exception:
        return ts_str[:10] if len(ts_str) >= 10 else ts_str


def proj_label(name):
    parts = name.lstrip('-').split('-')
    skip = {
        'media', 'nvme4tb', 'DEV', 'mnt', 'network', 'nas', 'data',
        'cloud', 'bitmads', 'files', 'OneDrive', 'pitt', 'jss', 'hu',
        'home', 'Obsidian', 'pitt@jss.hu',
    }
    kept = [p for p in parts if p and p not in skip]
    if len(kept) > 2:
        kept = kept[-2:]
    if kept:
        return '/'.join(kept)
    all_parts = [p for p in parts if p]
    if all_parts:
        return '/'.join(all_parts[-2:])
    return '?'


def sanitize(s):
    return re.sub(r'[^\w\s-]', '', s).strip().replace(' ', '-')[:80]


def shell_quiet(cmd):
    try:
        return subprocess.check_output(
            cmd, shell=True, text=True, stderr=subprocess.DEVNULL
        ).strip()
    except Exception:
        return ''


def session_label(s):
    title = s.get('title') or '???'
    if s.get('renamed'):
        return f"{C_BWHITE}{title}{C_RESET}"
    elif s.get('auto_named'):
        return f"{C_WHITE}{title}{C_RESET}"
    else:
        return f"{C_DIM}{title}{C_RESET}"


def ctx_bar(tokens, max_tokens=1_000_000, width=5):
    if not tokens:
        return ''
    pct = min(tokens / max_tokens, 1.0)
    filled = round(pct * width)
    empty = width - filled
    pct_int = int(pct * 100)

    if pct < 0.5:
        color = C_GREEN
    elif pct < 0.8:
        color = C_YELLOW
    else:
        color = '\033[31m'

    bar = f"{color}{'█' * filled}{C_DIM}{'░' * empty}{C_RESET}"
    return f"{bar} {color}{pct_int}%{C_RESET}"


def _term_width():
    for var in ('FZF_COLUMNS', 'COLUMNS'):
        v = os.environ.get(var)
        if v:
            try:
                return int(v)
            except ValueError:
                pass
    for fd in (1, 0, 2):
        try:
            return os.get_terminal_size(fd).columns
        except OSError:
            continue
    try:
        out = subprocess.check_output(
            ['stty', 'size'], stderr=subprocess.DEVNULL,
            stdin=open('/dev/tty'),
        )
        return int(out.split()[1])
    except Exception:
        pass
    return 100


# ── Rendering pipeline ──────────────────────────────────────────────

def _filter_scope(sessions, scope):
    if scope == 'all':
        return sessions
    cwd = os.getcwd()
    return [s for s in sessions if s.get('cwd', '').startswith(cwd)]


VIEWS = [
    ('project', 'recent', 'Grouped·Date'),
    ('project', 'alpha',  'Grouped·A-Z'),
    ('none',    'recent', 'Flat·Date'),
    ('none',    'alpha',  'Flat·A-Z'),
]


def _build_rows(sessions, scope, view_idx):
    filtered = _filter_scope(sessions, scope)
    group_mode, sort_mode, _ = VIEWS[view_idx]
    rows = []

    if not filtered:
        rows.append({
            'sid': '__header__', 'is_header': True,
            'name_str': f"  {C_DIM}No sessions in this scope{C_RESET}",
            'ts': '', 'bar': '', 'bar_tokens': 0, 'sid8': '',
            'task_key': None,
        })
        return rows

    if group_mode == 'none':
        if sort_mode == 'alpha':
            filtered.sort(key=lambda s: (s.get('title') or '').lower())
        else:
            filtered.sort(key=lambda s: s.get('last_ts') or '', reverse=True)

        for s in filtered:
            title = s.get('title') or '???'
            proj = proj_label(s.get('project', ''))
            ctx = s.get('ctx_tokens', 0)

            if s.get('renamed'):
                icon = f"{C_GREEN}★{C_RESET}"
                label = f"{C_BCYAN}{title}{C_RESET}"
            elif s.get('auto_named'):
                icon = f"{C_CYAN}○{C_RESET}"
                label = f"{C_BCYAN}{title}{C_RESET}"
            else:
                icon = f"{C_DIM}·{C_RESET}"
                label = f"{C_DIM}{title}{C_RESET}"

            rows.append({
                'sid': s['session_id'], 'is_header': False,
                'name_str': f"  {icon} {label}  {C_DIM}{proj}{C_RESET}",
                'ts': fmt_ts(s.get('last_ts')),
                'bar': ctx_bar(ctx) if ctx else '',
                'bar_tokens': ctx,
                'sid8': s['session_id'][:8],
                'task_key': s.get('task_key'),
            })
    else:
        groups = group_sessions(filtered)

        if sort_mode == 'alpha':
            def proj_then_alpha(kv):
                proj = proj_label(kv[1][0].get('project', ''))
                return (proj.lower(), kv[0].lower())
            groups = sorted(groups, key=proj_then_alpha)

        by_project = {}
        for task_key, slist in groups:
            proj = proj_label(slist[0].get('project', ''))
            by_project.setdefault(proj, []).append((task_key, slist))

        for proj, proj_groups in by_project.items():
            rows.append({
                'sid': '__header__', 'is_header': True,
                'name_str': f"  {C_BYELLOW}━━ {proj} ━━{C_RESET}",
                'ts': '', 'bar': '', 'bar_tokens': 0, 'sid8': '',
                'task_key': None,
            })

            for task_key, slist in proj_groups:
                n = len(slist)
                max_ctx = max((s.get('ctx_tokens', 0) for s in slist), default=0)
                has_renamed = any(s.get('renamed') for s in slist)
                icon = '★' if has_renamed else '○'

                status = _get_task_status(task_key)
                si_icon = STATUS_ICONS.get(status, '○')
                si_color = STATUS_COLORS.get(status)
                if si_color:
                    status_str = f"\033[{32 if si_color == _CP_GREEN else 33 if si_color == _CP_YELLOW else 31}m{si_icon}\033[0m"
                else:
                    status_str = f"{C_DIM}{si_icon}{C_RESET}"

                if n == 1:
                    s = slist[0]
                    rows.append({
                        'sid': s['session_id'], 'is_header': False,
                        'name_str': f"  {status_str} {C_BCYAN}{task_key}{C_RESET}",
                        'ts': fmt_ts(s.get('last_ts')),
                        'bar': ctx_bar(max_ctx) if max_ctx else '',
                        'bar_tokens': max_ctx,
                        'sid8': s['session_id'][:8],
                        'task_key': task_key,
                    })
                else:
                    rows.append({
                        'sid': '__header__', 'is_header': True,
                        'name_str': f"  {status_str} {C_BCYAN}{task_key}{C_RESET}",
                        'ts': fmt_ts(slist[0].get('last_ts')),
                        'bar': ctx_bar(max_ctx) if max_ctx else '',
                        'bar_tokens': max_ctx,
                        'sid8': '',
                        'task_key': task_key,
                    })

                    for si, s in enumerate(slist):
                        is_last = (si == n - 1)
                        conn = T_LAST if is_last else T_BRANCH
                        title = s.get('title') or '???'

                        if s.get('renamed'):
                            tag = f"{C_GREEN}●{C_RESET}"
                            label = f"{C_BWHITE}{title}{C_RESET}"
                        elif s.get('auto_named'):
                            tag = f"{C_CYAN}○{C_RESET}"
                            label = f"{C_WHITE}{title}{C_RESET}"
                        else:
                            tag = f"{C_DIM}·{C_RESET}"
                            label = f"{C_DIM}{title}{C_RESET}"

                        ctx = s.get('ctx_tokens', 0)
                        rows.append({
                            'sid': s['session_id'], 'is_header': False,
                            'name_str': f"  {C_DIM}{conn}{C_RESET} {tag} {label}",
                            'ts': fmt_ts(s.get('last_ts')),
                            'bar': ctx_bar(ctx) if ctx else '',
                            'bar_tokens': ctx,
                            'sid8': s['session_id'][:8],
                            'task_key': task_key,
                        })

    return rows


# ── Curses picker ────────────────────────────────────────────────────

_CP_CYAN = 1
_CP_GREEN = 2
_CP_YELLOW = 3
_CP_WHITE = 4
_CP_RED = 5
_CP_SEL = 6
_CP_BAR = 9
_CP_BAR_ACC = 10
_CP_PANEL_CYAN = 11


def _sgr_to_attr(codes):
    attr = 0
    for code in codes:
        if code == 0:
            attr = 0
        elif code == 1:
            attr |= curses.A_BOLD
        elif code == 2:
            attr |= curses.A_DIM
        elif code == 31:
            attr |= curses.color_pair(_CP_RED)
        elif code == 32:
            attr |= curses.color_pair(_CP_GREEN)
        elif code == 33:
            attr |= curses.color_pair(_CP_YELLOW)
        elif code == 36:
            attr |= curses.color_pair(_CP_CYAN)
        elif code == 37:
            attr |= curses.color_pair(_CP_WHITE)
    return attr


def _caddstr(win, y, x, s, max_col):
    attr = 0
    col = x
    i = 0
    while i < len(s) and col < max_col:
        if s[i] == '\033' and i + 1 < len(s) and s[i + 1] == '[':
            j = i + 2
            while j < len(s) and not s[j].isalpha():
                j += 1
            if j < len(s) and s[j] == 'm':
                code_str = s[i+2:j]
                codes = [int(c) for c in code_str.split(';') if c.strip().isdigit()]
                if not codes:
                    codes = [0]
                attr = _sgr_to_attr(codes)
            i = j + 1 if j < len(s) else len(s)
        else:
            try:
                win.addstr(y, col, s[i], attr)
            except curses.error:
                pass
            col += 1
            i += 1
    return col


def _draw_bar_curses(win, y, col, tokens, max_col, max_tokens=1_000_000, width=5):
    if not tokens or col >= max_col:
        return
    pct = min(tokens / max_tokens, 1.0)
    filled = round(pct * width)
    empty = width - filled
    pct_int = int(pct * 100)

    if pct < 0.5:
        pair = _CP_GREEN
    elif pct < 0.8:
        pair = _CP_YELLOW
    else:
        pair = _CP_RED

    try:
        win.addstr(y, col, '█' * filled, curses.color_pair(pair))
        win.addstr(y, col + filled, '░' * empty, curses.A_DIM)
        pct_str = f" {pct_int}%"
        win.addstr(y, col + width, pct_str, curses.color_pair(pair))
    except curses.error:
        pass


def _draw_tab_bar(win, y, tw, scope, view_idx):
    col = 1
    for label, is_active in [('Current', scope == 'cwd'), ('All', scope == 'all')]:
        if is_active:
            attr = curses.A_BOLD | curses.color_pair(_CP_CYAN)
        else:
            attr = curses.A_DIM
        text = f' {label} '
        try:
            win.addstr(y, col, text, attr)
        except curses.error:
            pass
        col += len(text)

    try:
        win.addstr(y, col, ' │ ', curses.A_DIM)
    except curses.error:
        pass
    col += 3

    for i, (_, _, label) in enumerate(VIEWS):
        is_active = (i == view_idx)
        if is_active:
            attr = curses.A_BOLD | curses.color_pair(_CP_CYAN)
        else:
            attr = curses.A_DIM
        text = f' {label} '
        try:
            win.addstr(y, col, text, attr)
        except curses.error:
            pass
        col += len(text)

    hint = ' │  Tab: scope  ⇧Tab: view'
    try:
        win.addstr(y, col, hint, curses.A_DIM)
    except curses.error:
        pass


def _draw_row(win, y, tw, row, selected=False):
    BAR_W = 10
    R_PAD = 2
    RIGHT_W = 2 + 7 + 2 + BAR_W + 2 + 8 + R_PAD
    name_max = tw - RIGHT_W
    ts_col = name_max + 2
    bar_col = ts_col + 7 + 2
    sid_col = bar_col + BAR_W + 2

    if row['is_header'] and not row['ts']:
        _caddstr(win, y, 0, row['name_str'], tw)
        return

    if selected:
        try:
            win.addstr(y, 0, ' ' * (tw - 1), curses.color_pair(_CP_SEL))
        except curses.error:
            pass

    name = row['name_str']
    name_vis = _vis_len(name)
    if name_vis > name_max:
        name = _ansi_truncate(name, max(name_max - 1, 3)) + '…'

    if selected:
        plain = ANSI_RE.sub('', name)
        if len(plain) > name_max:
            plain = plain[:name_max - 1] + '…'
        try:
            win.addstr(y, 0, plain[:name_max], curses.color_pair(_CP_SEL) | curses.A_BOLD)
        except curses.error:
            pass
    else:
        _caddstr(win, y, 0, name, name_max)

    ts = row['ts']
    if ts:
        attr = (curses.color_pair(_CP_SEL) | curses.A_BOLD) if selected else curses.A_DIM
        try:
            win.addstr(y, ts_col, f"{ts:>7s}", attr)
        except curses.error:
            pass

    bar_tokens = row.get('bar_tokens', 0)
    if bar_tokens:
        _draw_bar_curses(win, y, bar_col, bar_tokens, sid_col)

    sid8 = row['sid8']
    if sid8:
        attr = (curses.color_pair(_CP_SEL)) if selected else curses.A_DIM
        try:
            win.addstr(y, sid_col, sid8, attr)
        except curses.error:
