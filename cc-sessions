def cmd_note(task=None, text=None):
    NOTES_DIR.mkdir(parents=True, exist_ok=True)
    if not task:
        notes = sorted(NOTES_DIR.glob("*.md"))
        if not notes:
            print("No task notes yet.")
            return
        for n in notes:
            content = n.read_text().strip()
            preview = content[:80].replace('\n', ' ') if content else '(empty)'
            print(f"  {C_BCYAN}{n.stem}{C_RESET}  {C_DIM}{preview}{C_RESET}")
        return

    note_file = NOTES_DIR / f"{sanitize(task)}.md"
    if text:
        with note_file.open('a') as f:
            f.write(f"\n{text}\n")
        print(f"Appended to {note_file}")
    elif note_file.exists():
        print(note_file.read_text())
    else:
        print(f"No notes for '{task}'.")
        print(f"Create with: cc-sessions note '{task}' 'your note text'")


