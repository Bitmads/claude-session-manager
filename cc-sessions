def _bg_refresh(state, stop_evt):
    """Watch transcripts; re-scan only when the cheap signature changes."""
    while not stop_evt.wait(1.0):
        try:
            sig = _transcript_signature()
            if sig != state['sig']:
                fresh = scan_transcripts()
                state['sessions'] = fresh
                state['sig'] = sig
        except Exception:
            pass


def cmd_pick():
    sessions = scan_transcripts()
    if not sessions:
        print("No sessions found.")
        return

    state = {'sessions': sessions, 'sig': _transcript_signature()}
    stop_evt = threading.Event()
    worker = threading.Thread(target=_bg_refresh, args=(state, stop_evt), daemon=True)
    worker.start()

    try:
        selected = curses.wrapper(lambda stdscr: _pick_loop(stdscr, state))
    except curses.error:
        selected = None
    finally:
        stop_evt.set()

    if not selected:
        return

    sid = selected['session_id']
    cwd = selected.get('cwd', '')
    print(f"{C_BOLD}Resuming:{C_RESET} {selected.get('title', sid)}")
    print(f"{C_DIM}  session: {sid}{C_RESET}")
    if cwd:
        print(f"{C_DIM}  dir:     {cwd}{C_RESET}")

    cmd_args = ['claude', '--resume', sid]
    if cwd and os.path.isdir(cwd):
        os.chdir(cwd)
    os.execvp('claude', cmd_args)


